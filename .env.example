# Copy this file to .env and fill in real values. The .env file is gitignored.
# Both docker-compose and the backend (via DotNetEnv) read from this file.

# ── Postgres (Supabase pooler connection string) ───────────────────────────
CONNECTION_STRING=

# ── Blockchain (Hardhat local node defaults shown) ─────────────────────────
BLOCKCHAIN_RPC_URL=http://host.docker.internal:8545
BLOCKCHAIN_CONTRACT_ADDRESS=

# ── Supabase storage ───────────────────────────────────────────────────────
# Project URL: https://YOUR_PROJECT.supabase.co
# service_role secret (NOT anon key) — has full DB/storage privileges, never commit.
Supabase__Url=
Supabase__ServiceRoleKey=
Supabase__DocumentsBucket=worker-documents
